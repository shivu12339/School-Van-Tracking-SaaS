# Global — see infrastructure/env/*.example for staging/production
NODE_ENV=development
PROCESS_ROLE=all
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# API (Railway sets PORT automatically in production)
API_PORT=4000
API_PREFIX=api
API_VERSION=v1
JWT_ACCESS_SECRET=replace_with_strong_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_strong_secret_min_32_chars
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCK_DURATION_MINUTES=15
AUTH_LOCK_WINDOW_SECONDS=900
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_SESSION_CACHE_TTL_SECONDS=900
AUTH_PERMISSIONS_CACHE_TTL_SECONDS=300
AUTH_USE_SECURE_COOKIES=true
SAAS_DEFAULT_TRIAL_DAYS=14
SAAS_DEFAULT_GRACE_PERIOD_DAYS=7
SAAS_ANALYTICS_CACHE_TTL_SECONDS=60
SAAS_PLATFORM_ANALYTICS_CACHE_TTL_SECONDS=120
SAAS_ENFORCE_SUBSCRIPTION=true

# Database — local docker-compose; Supabase uses pooler + direct URLs
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/schoolvan?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/schoolvan?schema=public

# Redis — local docker; Upstash uses rediss://
REDIS_URL=redis://localhost:6379

# Firebase FCM (FCM v1 via Firebase Admin SDK)
FCM_PROJECT_ID=replace
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Optional: path to service account JSON instead of env vars above
FCM_CREDENTIALS_PATH=

# Notification queues (BullMQ uses REDIS_URL)
# PROCESS_ROLE=all     — API + inline workers
# PROCESS_ROLE=worker  — BullMQ workers only (notifications + tracking persist)

# Maps, observability, media
GOOGLE_MAPS_API_KEY=replace
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=schoolvan/dev

# Web (Vercel)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_BASE_URL=http://localhost:4000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace
API_INTERNAL_URL=http://localhost:4000/api/v1
