# API (proxied via Next.js /api/backend)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
API_INTERNAL_URL=http://localhost:4000/api/v1

# WebSocket (Socket.IO namespaces: /tracking, /notifications)
NEXT_PUBLIC_WS_BASE_URL=http://localhost:4000

# Google Maps (live tracking)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Cloudinary (optional uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Sentry (Vercel production)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
