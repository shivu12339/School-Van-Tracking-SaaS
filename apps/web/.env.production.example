# Vercel → Project → Settings → Environment Variables (Production)

# Railway public API host (no trailing slash on WS base)
NEXT_PUBLIC_API_BASE_URL=https://YOUR-PROJECT.up.railway.app/api/v1
NEXT_PUBLIC_WS_BASE_URL=https://YOUR-PROJECT.up.railway.app
API_INTERNAL_URL=https://YOUR-PROJECT.up.railway.app/api/v1

# Must match Railway JWT_ACCESS_SECRET exactly
JWT_ACCESS_SECRET=generate-minimum-32-character-secret-here

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace

# Optional
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NODE_ENV=production
