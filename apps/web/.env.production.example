# Vercel -> Project -> Settings -> Environment Variables (Production scope)
# Paste these AFTER the Railway API is deployed (you need its public URL).

# Public Railway API host. /api/v1 is REQUIRED on the REST base.
NEXT_PUBLIC_API_BASE_URL=https://YOUR-API.up.railway.app/api/v1

# Same Railway host, root only (no /api/v1, no /socket.io).
# env.ts auto-strips trailing /api/v1 and /socket.io if you slip up.
NEXT_PUBLIC_WS_BASE_URL=https://YOUR-API.up.railway.app

# Server-side (SSR + Next API routes) - usually identical to NEXT_PUBLIC_API_BASE_URL,
# but you can point this at an internal Railway hostname if you ever wire one up.
API_INTERNAL_URL=https://YOUR-API.up.railway.app/api/v1

# Must equal Railway's JWT_ACCESS_SECRET exactly so the Next middleware can
# verify access tokens issued by the API.
JWT_ACCESS_SECRET=replace-with-the-same-32+-char-secret-as-railway

# Optional: shows the live map. Restrict the key to *.vercel.app referrers.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

NODE_ENV=production
