# Development — local docker-compose + API on host
NODE_ENV=development
PROCESS_ROLE=all

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/schoolvan?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/schoolvan?schema=public
REDIS_URL=redis://localhost:6379

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
API_PORT=4000

JWT_ACCESS_SECRET=dev_access_secret_minimum_32_characters_long
JWT_REFRESH_SECRET=dev_refresh_secret_minimum_32_characters_long

FCM_PROJECT_ID=dev
FCM_CLIENT_EMAIL=dev@example.com
FCM_PRIVATE_KEY=dev

GOOGLE_MAPS_API_KEY=dev
SENTRY_DSN=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=schoolvan/dev

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_BASE_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000/api/v1
