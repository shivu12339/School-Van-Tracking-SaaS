# Local development (docker-compose postgres + redis)
NODE_ENV=development
PROCESS_ROLE=all

API_PORT=4000
API_PREFIX=api
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/schoolvan?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/schoolvan?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=local_dev_access_secret_min_32_chars!!
JWT_REFRESH_SECRET=local_dev_refresh_secret_min_32_chars!
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=30d

FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

GOOGLE_MAPS_API_KEY=
SENTRY_DSN=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=schoolvan/dev

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_BASE_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000/api/v1
