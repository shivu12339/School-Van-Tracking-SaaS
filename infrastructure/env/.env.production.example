# Full production reference — set in Railway / Vercel dashboards only.

# ─── Railway API + Worker ───────────────────────────────────────────────────
NODE_ENV=production
PROCESS_ROLE=api

DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10
DIRECT_DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres

REDIS_URL=rediss://default:[PASSWORD]@[name].upstash.io:6379

CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
FRONTEND_URL=https://your-app.vercel.app
WEB_APP_URL=https://your-app.vercel.app

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d

FCM_PROJECT_ID=replace
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY=replace
GOOGLE_MAPS_API_KEY=replace

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=schoolvan/production

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=info
API_PREFIX=api
API_VERSION=v1

# Worker service only
# PROCESS_ROLE=worker

# ─── Vercel (apps/web) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_WS_BASE_URL=https://api.yourdomain.com
API_INTERNAL_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
