{
  "name": "school-van-saas",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant school van tracking SaaS — monorepo",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@schoolvan/api",
    "dev:web": "turbo run dev --filter=@schoolvan/web",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rimraf node_modules/.cache",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:prod": "docker compose -f infrastructure/docker/docker-compose.prod.yml up --build",
    "smoke": "bash infrastructure/scripts/smoke-test.sh",
    "health": "bash infrastructure/scripts/health-check.sh",
    "validate:deploy": "node infrastructure/scripts/validate-production-env.mjs",
    "validate:live": "pwsh -File infrastructure/scripts/live-deploy-validate.ps1",
    "test:e2e:api": "pnpm --filter @schoolvan/api test:e2e",
    "qa:load": "k6 run tests/load/k6/api-health.js",
    "qa:all": "pnpm test && pnpm test:e2e:api",
    "db:migrate": "pnpm --filter @schoolvan/api prisma:deploy",
    "db:generate": "pnpm --filter @schoolvan/api prisma:generate",
    "db:seed": "pnpm --filter @schoolvan/api prisma:seed",
    "setup": "pnpm install && pnpm docker:up && pnpm db:generate && pnpm db:migrate && pnpm db:seed"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "@sentry/cli",
      "argon2",
      "bcrypt",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@schoolvan/config": "workspace:*",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3"
  }
}
