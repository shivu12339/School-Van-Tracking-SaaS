{
  "name": "@schoolvan/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, constants, and contracts for School Van SaaS",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "default": "./dist/constants/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "check-types": "tsc -p tsconfig.build.json --noEmit",
    "test": "echo \"@schoolvan/shared: no tests yet\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "devDependencies": {
    "@schoolvan/config": "workspace:*",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
