# Railway API — paste into Project → Variables (never commit real values).
# Template: infrastructure/env/.env.production.example

NODE_ENV=production
PROCESS_ROLE=api

# Supabase — pooler :6543 (runtime), direct :5432 (migrations)
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10
DIRECT_DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres

# Upstash — must use TLS
REDIS_URL=rediss://default:[PASSWORD]@[name].upstash.io:6379

# Vercel admin URL (+ localhost for local prod testing)
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
FRONTEND_URL=https://your-app.vercel.app
WEB_APP_URL=https://your-app.vercel.app

JWT_ACCESS_SECRET=generate-minimum-32-character-secret-here
JWT_REFRESH_SECRET=generate-different-32-character-secret-here
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d

# Required by env validation — use placeholders until Firebase is configured
FCM_PROJECT_ID=replace
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY=replace
GOOGLE_MAPS_API_KEY=replace

# Optional
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=schoolvan/production
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=info

API_PREFIX=api
API_VERSION=v1

# Set SKIP_PRISMA_MIGRATE=true if GitHub Actions already ran migrate before deploy
# SKIP_PRISMA_MIGRATE=false

# Railway injects PORT — do not set API_PORT in production
