# Railway API service variables (Project -> Variables).
# Copy each line into Railway's "Raw Editor" then replace bracketed values.
# Anything marked PLACEHOLDER passes Joi validation but disables the
# corresponding feature at runtime; replace with real credentials when ready.

# --- Required: runtime ---
NODE_ENV=production
PROCESS_ROLE=api
API_PREFIX=api
API_VERSION=v1

# --- Required: Supabase (pooler for runtime, direct for migrations) ---
DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10
DIRECT_DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# --- Required: Upstash Redis (TLS only) ---
REDIS_URL=rediss://default:[PASSWORD]@[NAME].upstash.io:6379

# --- Required: CORS + frontend ---
# Comma-separated list. Add Vercel domain after first deploy.
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
FRONTEND_URL=https://your-app.vercel.app
WEB_APP_URL=https://your-app.vercel.app

# --- Required: JWT (must be 32+ chars; generate with the helper script) ---
JWT_ACCESS_SECRET=replace-with-32-or-more-character-random-secret-aaaaaa
JWT_REFRESH_SECRET=replace-with-different-32-character-random-secret-bbbbb
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d

# --- Required by Joi but optional at runtime (placeholders disable the feature) ---
# Firebase / FCM push (FcmProvider auto-detects placeholders -> simulates push).
FCM_PROJECT_ID=placeholder-project
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY=placeholder-key

# Google Maps (server only validates presence; web supplies the real key).
GOOGLE_MAPS_API_KEY=placeholder-key

# --- Optional ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=schoolvan/production

LOG_LEVEL=info
WRITE_LOG_FILES=true

# Optional: skip prisma migrate deploy at boot (e.g. on worker replicas;
# run migrations from GitHub Actions or the API service instead).
SKIP_PRISMA_MIGRATE=false

# Railway injects PORT automatically -- DO NOT set API_PORT in production.
