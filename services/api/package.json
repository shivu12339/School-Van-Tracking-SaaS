{
  "name": "@schoolvan/api",
  "type": "commonjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest build && node scripts/write-dist-shim.cjs && nest start --watch",
    "build": "nest build && node scripts/write-dist-shim.cjs",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "clean": "rimraf dist coverage",
    "test": "jest --runInBand",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:integration": "jest --testPathPattern=test/integration --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:cov": "jest --coverage --runInBand",
    "check-types": "tsc --noEmit",
    "prisma:generate": "node -r ./prisma/load-env.cjs ./node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node -r ./prisma/load-env.cjs ./node_modules/prisma/build/index.js migrate dev",
    "prisma:deploy": "node -r ./prisma/load-env.cjs ./node_modules/prisma/build/index.js migrate deploy",
    "prisma:seed": "tsx -r ./prisma/load-env.cjs prisma/seed.ts",
    "prisma:reset": "node -r ./prisma/load-env.cjs ./node_modules/prisma/build/index.js migrate reset",
    "prisma:studio": "node -r ./prisma/load-env.cjs ./node_modules/prisma/build/index.js studio",
    "prisma:validate": "node -r ./prisma/load-env.cjs ./node_modules/prisma/build/index.js validate",
    "start:prod": "node dist/main.js",
    "start:worker": "node dist/worker.main.js"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.4",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.0.1",
    "@nestjs/swagger": "^11.1.2",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/websockets": "^11.0.1",
    "class-sanitizer": "^1.0.1",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "joi": "^17.13.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "nest-winston": "^1.10.2",
    "@prisma/client": "^6.7.0",
    "argon2": "^0.41.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.49.1",
    "firebase-admin": "^13.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "@sentry/node": "^9.22.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@schoolvan/config": "workspace:*",
    "rimraf": "^6.0.1",
    "@nestjs/cli": "^11.0.2",
    "@nestjs/schematics": "^11.0.1",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.3",
    "ioredis-mock": "^8.9.0",
    "jest-mock-extended": "^3.0.7",
    "supertest": "^7.1.0",
    "@types/node": "^22.15.19",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.18",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.26.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prisma": "^6.7.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx -r ./prisma/load-env.cjs prisma/seed.ts",
    "env:sync": "node -e \"require('fs').copyFileSync(require('path').join(__dirname,'../../.env'),require('path').join(__dirname,'.env'))\""
  }
}
